<ContentPage
    x:Class="TrafficEscape.MainMenuPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="Black">

    <VerticalStackLayout
        VerticalOptions="Center"
        HorizontalOptions="Center"
        Spacing="25">

        <!-- Game Title -->
        <Label Text="TRAFFIC ESCAPE"
               FontSize="40"
               TextColor="White"
               HorizontalOptions="Center"
               FontAttributes="Bold" />

        <!-- High Score -->
        <Label x:Name="HighScoreLabel"
               Text="High Score: 0"
               FontSize="24"
               TextColor="Gold"
               HorizontalOptions="Center" />

        <!-- Start Game Button -->
        <Button Text="START GAME"
                Clicked="StartGame_Clicked"
                WidthRequest="220"
                HeightRequest="55"
                BackgroundColor="#CC0000"
                TextColor="White"
                FontAttributes="Bold"
                CornerRadius="10" />

        <!-- Options Button -->
        <Button Text="OPTIONS"
                WidthRequest="220"
                HeightRequest="55"
                BackgroundColor="Gray"
                TextColor="White"
                FontAttributes="Bold"
                CornerRadius="10" />

    </VerticalStackLayout>

</ContentPage>
