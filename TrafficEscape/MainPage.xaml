<ContentPage
    x:Class="TrafficEscape.GamePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid BackgroundColor="Gray">
        <Grid RowDefinitions="*, 80">

            <!-- Top area (PlayArea) -->
            <Grid x:Name="PlayArea" Grid.Row="0">

                <!-- Drawn road behind car -->
                <GraphicsView x:Name="RoadView"
                              VerticalOptions="FillAndExpand"
                              HorizontalOptions="FillAndExpand" />

                <!-- Player Car on top -->
                <Image x:Name="PlayerCar"
                       Source="player_car.png"
                       WidthRequest="90"
                       HeightRequest="140"
                       VerticalOptions="End"
                       HorizontalOptions="Center"
                       Margin="0,0,0,20"
                       Rotation="180"/>
            </Grid>

            <!-- Bottom area = left/right buttons -->
            <Grid Grid.Row="1"
                  HorizontalOptions="Center"
                  VerticalOptions="Center">

                <StackLayout Orientation="Horizontal"
                             Spacing="20"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">

                    <Button Text="◀"
                            WidthRequest="80"
                            HeightRequest="60"
                            BackgroundColor="Black"
                            TextColor="White"
                            Clicked="MoveLeft"/>

                    <Button Text="▶"
                            WidthRequest="80"
                            HeightRequest="60"
                            BackgroundColor="Black"
                            TextColor="White"
                            Clicked="MoveRight"/>

                </StackLayout>

            </Grid>
        </Grid>
    </Grid>

</ContentPage>




